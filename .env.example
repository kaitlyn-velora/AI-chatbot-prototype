# Local dev: copy to .env.local (never commit real keys).
# Vercel: set GEMINI_API_KEY (and optional GEMINI_MODEL) in Project → Settings → Environment Variables, then redeploy.

GEMINI_API_KEY=

# Optional (default: gemini-3-flash-preview). Override for other models, e.g. gemini-2.5-flash
# GEMINI_MODEL=gemini-3-flash-preview
